<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Circle.AI.Sync</PackageId>
    <Description>Memory delta sync for Circle AI. Episodic memory, affect state, and persona deltas propagate across all devices via any transport (gRPC, mesh, DTN). This is the cross-device continuity layer.</Description>
  </PropertyGroup>
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Circle.AI.Identity\Circle.AI.Identity.csproj" />
    <ProjectReference Include="..\Circle.AI.Memory\Circle.AI.Memory.csproj" />
    <ProjectReference Include="..\Circle.AI.Networking\Circle.AI.Networking.csproj" />
  </ItemGroup>
</Project>
