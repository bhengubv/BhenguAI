<Project Sdk="Microsoft.NET.Sdk">

  <!-- ========== NUGET IDENTITY ========== -->
  <PropertyGroup>
    <PackageId>Circle.AI.Security.Aether</PackageId>
    <Description>
      Aether mesh bridge for Circle.AI.Security.
      Translates Aether telemetry events into transport-agnostic PeerSecurityEvents
      and adapts the transport-agnostic intelligence output to implement
      IAetherIntelligence and IAISecurityLayer.
      Requires Circle.AI.Security (base layer) and Circle.AI.Aether (mesh contracts).
    </Description>
  </PropertyGroup>

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Circle.AI.Security\Circle.AI.Security.csproj" />
    <ProjectReference Include="..\Circle.AI.Aether\Circle.AI.Aether.csproj" />
  </ItemGroup>

</Project>
