<Project Sdk="Microsoft.NET.Sdk">

  <!-- ========== NUGET IDENTITY ========== -->
  <PropertyGroup>
    <PackageId>Bhengu.AI.Tools</PackageId>
    <Description>Function-calling bridge between Bhengu AI agents and the TheGeekNetwork API ecosystem (36 APIs, 1 600+ endpoints).</Description>
  </PropertyGroup>

	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\Bhengu.AI.Core\Bhengu.AI.Core.csproj" />
	</ItemGroup>

	<PropertyGroup>
		<!-- Disable RID-specific asset warnings -->
		<EnableRuntimeIdentifierChecking>false</EnableRuntimeIdentifierChecking>

		<PublishReadyToRun>false</PublishReadyToRun>
		<StripSymbols>true</StripSymbols>
	</PropertyGroup>
</Project>
