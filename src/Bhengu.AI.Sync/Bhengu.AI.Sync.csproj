<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Bhengu.AI.Sync</PackageId>
    <Description>Memory delta sync for Circle AI. Episodic memory, affect state, and persona deltas propagate across all devices via any transport (gRPC, mesh, DTN). This is the cross-device continuity layer.</Description>
  </PropertyGroup>
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Bhengu.AI.Identity\Bhengu.AI.Identity.csproj" />
    <ProjectReference Include="..\Bhengu.AI.Memory\Bhengu.AI.Memory.csproj" />
    <ProjectReference Include="..\Bhengu.AI.Networking\Bhengu.AI.Networking.csproj" />
  </ItemGroup>
</Project>
