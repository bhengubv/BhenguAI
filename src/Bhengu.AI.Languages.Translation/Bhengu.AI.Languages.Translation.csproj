<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Bhengu.AI.Languages.Translation</PackageId>
    <Description>On-device real-time translation for Circle AI. No API call, no data leaving device. Context-aware, live conversation mode, document translation.</Description>
  </PropertyGroup>
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Bhengu.AI.Languages\Bhengu.AI.Languages.csproj" />
    <ProjectReference Include="..\Bhengu.AI.Inference\Bhengu.AI.Inference.csproj" />
  </ItemGroup>
</Project>
