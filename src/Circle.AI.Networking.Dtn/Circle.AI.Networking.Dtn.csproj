<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Circle.AI.Networking.Dtn</PackageId>
    <Description>DTN store-and-forward for Circle AI. 72hr TTL bundles with custody transfer over any transport. Delivers when a path exists.</Description>
  </PropertyGroup>
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Circle.AI.Networking\Circle.AI.Networking.csproj" />
  </ItemGroup>
</Project>
