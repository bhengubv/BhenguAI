<Project Sdk="Microsoft.NET.Sdk">

  <!-- ========== NUGET IDENTITY ========== -->
  <PropertyGroup>
    <PackageId>Bhengu.AI.Networking</PackageId>
    <Description>
      Transport-agnostic networking abstractions for Circle AI.
      INetworkTransport / ISyncChannel work across HTTP, WebSocket, gRPC, MQTT,
      TCP, WiFi Direct, BLE GATT, NearLink, Aether mesh, and DTN bundles.
      Specific transports live in Bhengu.AI.Networking.* sub-packages.
    </Description>
  </PropertyGroup>

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

</Project>
