    <ProjectReference Include="..\Circle.AI.Languages.Translation\Circle.AI.Languages.Translation.csproj" />
    <ProjectReference Include="..\Circle.AI.Voice\Circle.AI.Voice.csproj" />
    <ProjectReference Include="..\Circle.AI.Tools\Circle.AI.Tools.csproj" />
    <ProjectReference Include="..\Circle.AI.Hosting\Circle.AI.Hosting.csproj" />
    <ProjectReference Include="..\Circle.AI.Networking\Circle.AI.Networking.csproj" />
