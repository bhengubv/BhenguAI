<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Circle.AI.Identity</PackageId>
    <Description>Cross-device identity for Circle AI. Unified persona key that travels with the person — not the device. Foundation for Circle.AI.Sync.</Description>
  </PropertyGroup>
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Circle.AI.Core\Circle.AI.Core.csproj" />
  </ItemGroup>
</Project>
