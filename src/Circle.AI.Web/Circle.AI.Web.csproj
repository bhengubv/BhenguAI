<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Circle.AI.Web</PackageId>
    <Description>Circle AI surface adapter for browser-hosted experiences (Blazor Server / WebAssembly).
Exposes the Companion as a streaming Blazor-compatible service with
SSR-safe session management.</Description>
  </PropertyGroup>
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Circle.AI.Companion\Circle.AI.Companion.csproj" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.0" />
  </ItemGroup>
</Project>
